{
  "name": "certificate-template-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c cyan,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:backend": "cd ../backend && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/node": "22.10.5",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "lucide-react": "0.468.0",
    "next": "^16.2.7",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-pdf": "9.2.1",
    "typescript": "5.7.2"
  },
  "devDependencies": {
    "autoprefixer": "10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
